# === Database ===
# POSTGRES_URL=jdbc:postgresql://localhost:5432/esports_db
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=esports_db
POSTGRES_USER=
POSTGRES_PASSWORD=

# === Auth ===
# JWT_SECRET: 최소 32자 이상의 랜덤 문자열 (openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# === Admin ===
ADMIN_USERNAME=
ADMIN_PASSWORD=

# === External Data API (Phase 1 — 검토 후 선택) ===
PANDASCORE_API_KEY=
# RIOT_API_KEY=

# === AI / LLM (Phase 4) ===
# Hard Rule: no hardcoded secrets — 모든 AI API 키는 환경변수로만
# Gemini (기본값 — 무료 티어)
GEMINI_API_KEY=
# Claude (선택 — 유료)
CLAUDE_API_KEY=
# 사용할 모델 (gemini-1.5-flash 또는 claude-3-haiku-20240307)
AI_MODEL=gemini-1.5-flash

# === PandaScore API (Phase 4) ===
PANDASCORE_API_KEY=

# === Feature Flags (default OFF) ===
# Hard Rule: AI_ENABLED 기본값 0 — 명시적으로 1로 설정해야 활성화
AI_ENABLED=0
# 일일 AI API 비용 한도 (USD) — 초과 시 자동 비활성화 (Hard Rule)
AI_DAILY_COST_LIMIT_USD=1.00

# === App Config ===
SERVER_PORT=8080
LOG_LEVEL=INFO

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8080

# === Deployment ===
# COOKIE_SECURE: HTTPS 운영 환경에서 true로 설정 (Railway/AWS 배포 시)
COOKIE_SECURE=false
# BACKEND_INTERNAL_URL: nginx proxy_pass 대상 (Docker Compose는 http://backend:8080)
BACKEND_INTERNAL_URL=http://backend:8080
