# === Database ===
# POSTGRES_URL=jdbc:postgresql://localhost:5432/esports_db
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=esports_db
POSTGRES_USER=
POSTGRES_PASSWORD=

# === Auth ===
# JWT_SECRET: 최소 32자 이상의 랜덤 문자열 (openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# === Admin ===
ADMIN_USERNAME=
ADMIN_PASSWORD=

# === External Data API (Phase 1 — 검토 후 선택) ===
PANDASCORE_API_KEY=
# RIOT_API_KEY=

# === AI / LLM (Phase 4) ===
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# === Feature Flags (default OFF) ===
AI_ENABLED=0

# === App Config ===
SERVER_PORT=8080
LOG_LEVEL=INFO

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8080

# === Deployment ===
# COOKIE_SECURE: HTTPS 운영 환경에서 true로 설정 (Railway/AWS 배포 시)
COOKIE_SECURE=false
# BACKEND_INTERNAL_URL: nginx proxy_pass 대상 (Docker Compose는 http://backend:8080)
BACKEND_INTERNAL_URL=http://backend:8080
