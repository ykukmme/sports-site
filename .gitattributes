# 텍스트 파일 — 체크아웃 시 OS 기본 줄바꿈, 저장소는 LF 통일
* text=auto eol=lf

# Windows 전용 파일은 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리 파일 — 줄바꿈 변환 없음
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.jar binary
*.class binary
